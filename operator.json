{
  "schema_version": "operator.v0",
  "name": "vacuum",
  "version": "0.5.0",
  "description": "Enumerates artifacts in scope, emitting a stable JSONL manifest of files and metadata",
  "repository": "https://github.com/cmdrvl/vacuum",
  "license": "MIT",
  "agent_guide": "https://github.com/cmdrvl/.github/blob/main/profile/AGENT_PROMPT.md",
  "invocation": {
    "binary": "vacuum",
    "output_mode": "stream",
    "output_schema": "vacuum.v0",
    "json_flag": "--json"
  },
  "commands": [
    {
      "name": "capabilities",
      "usage": "vacuum capabilities --json",
      "description": "Describe supported agent-facing command surfaces and side-effect policy"
    },
    {
      "name": "robot-docs",
      "usage": "vacuum robot-docs guide",
      "description": "Print the agent-oriented command guide"
    },
    {
      "name": "doctor",
      "usage": "vacuum doctor --robot-triage",
      "description": "Run read-only health checks and diagnostics"
    },
    {
      "name": "witness",
      "usage": "vacuum witness <query|last|count> [OPTIONS]",
      "description": "Query the ambient witness ledger"
    }
  ],
  "arguments": [
    {
      "name": "roots",
      "type": "file_path[]",
      "required": true,
      "variadic": true,
      "description": "Root directories to scan (not individual files)"
    }
  ],
  "options": [
    {
      "name": "include",
      "flag": "--include",
      "type": "string",
      "repeatable": true,
      "description": "Include glob pattern"
    },
    {
      "name": "exclude",
      "flag": "--exclude",
      "type": "string",
      "repeatable": true,
      "description": "Exclude glob pattern"
    },
    {
      "name": "no_follow",
      "flag": "--no-follow",
      "type": "boolean",
      "description": "Do not follow symlinks"
    },
    {
      "name": "no_witness",
      "flag": "--no-witness",
      "type": "boolean",
      "description": "Suppress witness ledger recording"
    },
    {
      "name": "json",
      "flag": "--json",
      "type": "boolean",
      "description": "Accepted explicit machine-output intent; scan stdout is already JSONL"
    },
    {
      "name": "robot_triage",
      "flag": "--robot-triage",
      "type": "boolean",
      "description": "Emit health, capability, and command guidance in one JSON payload"
    },
    {
      "name": "describe",
      "flag": "--describe",
      "type": "boolean",
      "description": "Print operator manifest JSON and exit"
    },
    {
      "name": "schema",
      "flag": "--schema",
      "type": "boolean",
      "description": "Print the vacuum.v0 JSON Schema and exit"
    },
    {
      "name": "progress",
      "flag": "--progress",
      "type": "boolean",
      "description": "Emit structured progress JSONL to stderr"
    }
  ],
  "exit_codes": {
    "0": {
      "meaning": "SCAN_COMPLETE",
      "domain": "positive"
    },
    "2": {
      "meaning": "REFUSAL",
      "domain": "error"
    }
  },
  "refusals": [
    {
      "code": "E_ROOT_NOT_FOUND",
      "message": "Root path doesn't exist",
      "action": "escalate"
    },
    {
      "code": "E_ROOT_PERMISSION",
      "message": "Can't read root",
      "action": "escalate"
    },
    {
      "code": "E_IO",
      "message": "Filesystem error during scan",
      "action": "check_root_or_scan_parent",
      "hint": "vacuum scans directories, not individual files"
    }
  ],
  "capabilities": {
    "formats": [
      "*"
    ],
    "profile_aware": false,
    "streaming": true,
    "agent_discovery": {
      "capabilities_json": "vacuum capabilities --json",
      "robot_triage": "vacuum --robot-triage",
      "robot_docs": "vacuum robot-docs guide"
    }
  },
  "pipeline": {
    "upstream": [],
    "downstream": [
      "hash"
    ]
  }
}
